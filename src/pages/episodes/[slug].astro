---
import Base from '../../layouts/Base.astro';
import { getShow } from '../../lib/episodes.js';
import { SITE, PLATFORMS } from '../../config.js';

export async function getStaticPaths() {
  const show = await getShow();
  return show.episodes.map((episode) => ({
    params: { slug: episode.slug },
    props: { episode },
  }));
}

const { episode: ep } = Astro.props;

// Hand-migrated transcripts live in src/notes/ as {sNeN}.html — matched by
// episode number. They take precedence over the feed transcript; the feed
// is only used as a fallback when no local file exists.
const noteFiles = import.meta.glob('../../notes/*.html', {
  query: '?raw',
  import: 'default',
  eager: true,
});
const noteKey = ep.idShort
  ? Object.keys(noteFiles).find((p) => p.endsWith(`/${ep.idShort.toLowerCase()}.html`))
  : null;
const localTranscript = noteKey ? noteFiles[noteKey] : null;

// Feed transcripts are flat plain text with no markup, but Transistor's
// auto-generated ones still write short standalone section labels (e.g.
// "Resources", "Component 1: Consistent Entity Naming") as their own
// blank-line-delimited block. Treat those as headings instead of body text.
const isHeadingLike = (block) =>
  block.length > 0 &&
  block.length <= 70 &&
  !block.includes('\n') &&
  !/[.!?:]$/.test(block);

const transcriptBlocks = ep.transcript
  ? ep.transcript
      .split(/\n{2,}/)
      .map((block) => block.trim())
      .filter(Boolean)
      .map((block) => ({ text: block, heading: isHeadingLike(block) }))
  : [];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'PodcastEpisode',
  name: ep.title,
  url: new URL(`/episodes/${ep.slug}/`, SITE.url).href,
  datePublished: ep.dateISO,
  description: ep.citable,
  timeRequired: ep.durationSeconds ? `PT${Math.round(ep.durationSeconds / 60)}M` : undefined,
  episodeNumber: ep.number ?? undefined,
  partOfSeason: ep.season
    ? { '@type': 'PodcastSeason', seasonNumber: ep.season }
    : undefined,
  partOfSeries: {
    '@type': 'PodcastSeries',
    name: SITE.title,
    url: SITE.url,
  },
  associatedMedia: {
    '@type': 'AudioObject',
    contentUrl: ep.audioUrl,
    encodingFormat: ep.audioType,
  },
  author: { '@type': 'Person', name: SITE.author },
};
---

<Base title={ep.title} description={ep.citable} schema={schema} currentPath="/episodes/">
  <article>
    <header class="episode-head">
      <div class="record-line">
        {ep.id && <span class="field field--blue">{ep.id}</span>}
        <span class="field">{ep.dateLabel}</span>
        {ep.durationLabel && <span class="field">{ep.durationLabel}</span>}
      </div>
      <h1>{ep.title}</h1>
      {ep.citable && (
        <p class="citable"><mark>{ep.citable}</mark></p>
      )}
    </header>

    <div class="player-block">
      <p class="field" style="margin-bottom:0.5rem;">Listen // {ep.idShort ?? SITE.title}</p>
      <audio controls preload="none" src={ep.audioUrl}>
        Your browser doesn't support the audio element.
        <a href={ep.audioUrl}>Download the episode</a>.
      </audio>
    </div>

    <div class="notes" set:html={ep.descriptionHtml} />

    {(localTranscript || ep.transcript) && (
      <section class="transcript-block" aria-label="Episode transcript" data-open="true">
        <button type="button" class="transcript-tab" aria-expanded="true" aria-controls="transcript-panel">
          <span>Transcript</span>
          <svg class="transcript-tab-icon" viewBox="0 0 10 6" width="10" height="6" aria-hidden="true">
            <path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <div class="transcript-collapse">
          <div class="transcript-surface" id="transcript-panel">
            <div class="transcript-card notes">
              {localTranscript ? (
                <div set:html={localTranscript} />
              ) : (
                transcriptBlocks.map((block) =>
                  block.heading ? <h3>{block.text}</h3> : <p>{block.text}</p>
                )
              )}
            </div>
          </div>
        </div>
      </section>
    )}

    <section aria-label="Listen on your favorite platform">
      <p class="field">Also on</p>
      <ul class="platforms">
        {PLATFORMS.map((p) => (
          <li><a href={p.url} rel="noopener">{p.name}</a></li>
        ))}
      </ul>
    </section>

    <section class="cta-strip">
      <p class="field">Apply it</p>
      <h2>Want this working on your site?</h2>
      <p>
        The techniques in this episode run live on this page — structure, schema, and
        speed included. Irishguy Design Studio builds the same system for clients.
      </p>
      <a class="button" href={SITE.studioUrl} rel="noopener">Work with Irishguy</a>
    </section>
  </article>
</Base>

<script>
  const tab = document.querySelector('.transcript-tab');
  const block = tab && tab.closest('.transcript-block');
  if (tab && block) {
    tab.addEventListener('click', () => {
      const open = block.getAttribute('data-open') !== 'false';
      block.setAttribute('data-open', String(!open));
      tab.setAttribute('aria-expanded', String(!open));
    });
  }
</script>
